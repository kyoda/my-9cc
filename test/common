void assert(int expected, int actual, char *code) {
    if (expected == actual) {
        printf("%s => %d Passed\n", code, actual);
    } else {
        printf("%s: Failed\n", code);
        printf("%s => %d expected, but got: %d\n", code, expected, actual);
        exit(1);
    }
}

/*
    A sample variadic function used for `va_list` tests.
    This function is compiled with GCC because my compiler does not yet fully support `va_start` and `va_arg`.
*/
int add_all(int n, ...) {
    va_list ap;
    va_start(ap, n);

    int sum = 0;
    for (int i = 0; i < n; i++) {
        sum += va_arg(ap, int);
    }
    return sum;
}